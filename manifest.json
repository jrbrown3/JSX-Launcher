{
  "manifest_version": 3,
  "name": "JSX Launcher",
  "version": "1.0.0",
  "description": "Pick a local .jsx file and render it as a live React component in the browser.",
  "action": {
    "default_title": "Open JSX Launcher"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "sandbox": {
    "pages": ["sandbox.html"]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
